{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.oceanlabs.local/workflow-commander/schemas/phase-task-identity.schema.json",
  "title": "Workflow Commander Phase Task Identity",
  "description": "Schema for stable Hermes Phase Task identity derived from Project Work Item identity plus phase kind.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "identityKey",
    "projectWorkItemIdentityKey",
    "phaseKind",
    "derivedFrom",
    "identityKeyAlgorithm"
  ],
  "properties": {
    "schemaVersion": {
      "const": "workflow-phase-task-identity.v1"
    },
    "identityKey": {
      "type": "string",
      "minLength": 1
    },
    "projectWorkItemIdentityKey": {
      "type": "string",
      "minLength": 1
    },
    "phaseKind": {
      "const": "story_implementation"
    },
    "derivedFrom": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "uniqueItems": true,
      "items": {
        "enum": ["projectWorkItemIdentityKey", "phaseKind"]
      }
    },
    "workflowName": {
      "const": "bmad-create-and-dev-story"
    },
    "identityKeyAlgorithm": {
      "const": "phase-prefix-project-work-key-phase-kind-v1"
    }
  }
}

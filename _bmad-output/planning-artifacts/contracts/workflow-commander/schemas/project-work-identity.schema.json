{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.oceanlabs.local/workflow-commander/schemas/project-work-identity.schema.json",
  "title": "Workflow Commander Project Work Item Identity",
  "description": "Schema for stable Hermes Project Work Item identity derived from a bound project cwd, BMAD artifact path, and BMAD epic or story identity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "identityKey",
    "identityInputs",
    "derivedFrom",
    "identityKeyAlgorithm"
  ],
  "properties": {
    "schemaVersion": {
      "const": "workflow-project-work-identity.v1"
    },
    "identityKey": {
      "type": "string",
      "minLength": 1
    },
    "identityInputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundProjectCwd", "bmadArtifactPath", "bmadIdentity"],
      "properties": {
        "boundProjectCwd": {
          "type": "string",
          "minLength": 1
        },
        "bmadArtifactPath": {
          "type": "string",
          "minLength": 1
        },
        "bmadIdentity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "id"],
          "properties": {
            "kind": {
              "enum": ["epic", "story"]
            },
            "id": {
              "type": "string",
              "minLength": 1
            },
            "epicId": {
              "type": "string",
              "minLength": 1
            },
            "storyId": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "derivedFrom": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": {
        "enum": ["boundProjectCwd", "bmadArtifactPath", "bmadIdentity"]
      }
    },
    "identityKeyAlgorithm": {
      "const": "uri-component-encoded-identity-v1"
    }
  }
}
